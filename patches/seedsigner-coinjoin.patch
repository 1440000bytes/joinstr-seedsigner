+class PSBTCoinjoinOverviewView(View):
+    """joinstr coinjoin verification: show this peer's input/output/fee, then sign."""
+    APPROVE = ButtonOption("Sign my input")
+
+    def run(self):
+        from seedsigner.gui.screens.psbt_screens import PSBTCoinjoinOverviewScreen
+
+        psbt_parser: PSBTParser = self.controller.psbt_parser
+        if not psbt_parser or not psbt_parser.is_coinjoin:
+            return Destination(MainMenuView)
+
+        s = psbt_parser.coinjoin_summary
+        selected_menu_num = self.run_screen(
+            PSBTCoinjoinOverviewScreen,
+            num_participants=s["num_participants"],
+            my_input=s["my_input"],
+            my_output=s["my_output"],
+            my_fee=s["my_fee"],
+            denomination=s["denomination"],
+            button_data=[self.APPROVE],
+        )
+
+        if selected_menu_num == RET_CODE__BACK_BUTTON:
+            self.controller.psbt_seed = None
+            return Destination(BackStackView)
+
+        return Destination(PSBTFinalizeView)
+
