+    def _detect_coinjoin(self):
+        # joinstr signer view: one ANYONECANPAY input + >=2 equal-value outputs.
+        self.is_coinjoin = False
+        self.coinjoin_summary = None
+
+        if self.num_inputs != 1:
+            return
+        sighash = self.psbt.inputs[0].sighash_type
+        if sighash is None or (sighash & 0x80) == 0:   # ANYONECANPAY bit
+            return
+
+        values = [vout.value for vout in self.psbt.tx.vout]
+        denomination = max(set(values), key=values.count)
+        participants = values.count(denomination)
+        if participants < 2:
+            return
+
+        my_input = self.input_amount
+        my_output = self.change_amount if self.change_data else None
+        my_fee = (my_input - my_output) if my_output is not None else None
+
+        self.is_coinjoin = True
+        self.coinjoin_summary = {
+            "my_input": my_input,
+            "my_output": my_output,
+            "my_fee": my_fee,
+            "num_participants": participants,
+            "denomination": denomination,
+            "total_outputs": len(self.psbt.tx.vout),
+        }
+
